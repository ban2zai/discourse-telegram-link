<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Привязка Telegram</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      background: #f2f2f2;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .card {
      background: #ffffff;
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.10);
      padding: 40px 36px;
      max-width: 400px;
      width: 100%;
      text-align: center;
    }

    .card__logo {
      margin-bottom: 28px;
    }

    .card__logo img {
      height: 36px;
      width: auto;
    }

    .card__icon {
      font-size: 48px;
      line-height: 1;
      margin-bottom: 16px;
    }

    .card__title {
      font-size: 20px;
      font-weight: 600;
      color: #1c1c1c;
      margin-bottom: 8px;
    }

    .card__subtitle {
      font-size: 14px;
      color: #666666;
      line-height: 1.5;
      margin-bottom: 28px;
    }

    .card__subtitle strong {
      color: #1c1c1c;
    }

    .btn {
      display: inline-block;
      padding: 12px 28px;
      border-radius: 25px;
      font-size: 15px;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      background: #f5c842;
      color: #1c1c1c;
      transition: opacity 0.15s;
    }

    .btn:hover {
      opacity: 0.88;
    }

    .card--error .card__title {
      color: #c0392b;
    }
  </style>
</head>
<body>
  <div class="card<%= ' card--error' unless @success %>">

    <% if @logo_url.present? %>
      <div class="card__logo">
        <img src="<%= @logo_url %>" alt="Форум">
      </div>
    <% end %>

    <% if @success %>
      <div class="card__title">Telegram привязан</div>
      <div class="card__subtitle">
        Аккаунт <strong>@<%= @username %></strong> успешно привязан к Telegram
      </div>
      <% if @success_button_url.present? %>
        <a href="<%= @success_button_url %>" class="btn"><%= @success_button_label %></a>
      <% else %>
        <a href="/" class="btn">На главную</a>
      <% end %>
    <% else %>
      <div class="card__icon">❌</div>
      <div class="card__title">Ошибка</div>
      <div class="card__subtitle"><%= @error_message %></div>
      <a href="/" class="btn">На главную</a>
    <% end %>

  </div>
</body>
</html>
